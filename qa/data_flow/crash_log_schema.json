{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LGS Crash Log Schema",
  "type": "object",
  "required": ["timestamp","demo_id","platform","build_version","device_info","stack_trace"],
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "demo_id": { "type": "string" },
    "platform": { "type": "string" },
    "build_version": { "type": "string" },
    "device_info": {
      "type": "object",
      "properties": {
        "device_model": { "type": "string" },
        "os_version": { "type": "string" },
        "ram_mb": { "type": "integer" }
      }
    },
    "stack_trace": { "type": "string" },
    "breadcrumbs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "attachments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
